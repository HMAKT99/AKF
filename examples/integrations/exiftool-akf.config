# ExifTool config for AKF AI provenance tags
# Usage: exiftool -config exiftool-akf.config -XMP-akf:AIGenerated=true -XMP-akf:Agent="claude" image.jpg
#
# Install: copy this file to ~/.ExifTool_config
# Docs: https://akf.dev

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        akf => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::akf',
            },
        },
    },
);

%Image::ExifTool::UserDefined::akf = (
    GROUPS => { 0 => 'XMP', 1 => 'XMP-akf', 2 => 'Other' },
    NAMESPACE => { 'akf' => 'https://akf.dev/ns/1.0/' },
    WRITABLE => 'string',

    AIGenerated => { Writable => 'boolean' },
    Agent       => { },
    Model       => { },
    TrustScore  => { Writable => 'rational' },
    SourceTier  => { },
    Source       => { },
    Evidence    => { },
    GeneratedAt => { },
    Classification => {
        PrintConv => {
            'public'       => 'Public',
            'internal'     => 'Internal',
            'confidential' => 'Confidential',
        },
    },
    IntegrityHash  => { },
);

1; # end
